# ml-gateway environment template.
# Copy to ml-gateway/.env and fill in real values. The .env file is gitignored;
# never commit real secrets. docker-compose mounts this via `env_file`.

# --- Sarvam (primary S2S engine, paid API — use judiciously) ---
SARVAM_API_KEY=sk_replace_me
PROVIDER_PRECEDENCE=["sarvam","whisper"]
PROCEEDINGS_PROVIDER=sarvam
# Process-wide cap on concurrent Sarvam calls. 16 gives the full 22-language
# fanout (11 audio + 11 text-only) parallel headroom so audio TTS isn't queued
# behind text-only translates (measured audio tail: 3.9s@6, 2.6s@12, 1.3s@16;
# 24 no better + noisier). Sarvam showed no rate-limiting up to 24 concurrent.
SARVAM_CONCURRENCY_LIMIT=16

# --- Service auth (shared secret Laravel uses to call the gateway) ---
ML_GATEWAY_SERVICE_TOKEN=replace_me
ML_GATEWAY_AUTH_REQUIRED=true

# --- .132 local-LLM fallback (Sarvam stays primary; falls through on failure) ---
WHISPER_ENABLED=true
TIJORI_WHISPER_URL=http://10.21.217.132:18031
INDICTRANS2_ENDPOINT_URL=http://10.21.217.132:18032/v1/translate

# --- MinIO object storage (non-sensitive S2S audio archive + listener audio) ---
# Use a least-privilege scoped account, NOT MinIO root. Provision both the app
# and gateway accounts with: scripts/minio-scoped-accounts.sh
# (gateway -> user `vani-gateway`, policy vani-artifacts-rw on this bucket only).
# ARTIFACT_S3_ENDPOINT        : internal docker hostname the gateway uploads to.
# ARTIFACT_S3_PUBLIC_ENDPOINT : browser-reachable prefix Caddy reverse-proxies
#                               back to MinIO (the /minio-audio handle_path block);
#                               used only when minting presigned GET URLs.
# MONGODB_TRACE_WRITES_ENABLED: master "persist artifacts" switch — MUST be true
#                               or build_artifact_store() returns NoOp and audio
#                               is never archived (audio_url comes back null).
ARTIFACT_S3_ENDPOINT=http://vani-setu-minio:9000
ARTIFACT_S3_PUBLIC_ENDPOINT=https://vanisetu.rajyasabha.digital/minio-audio
ARTIFACT_S3_ACCESS_KEY=replace_me
ARTIFACT_S3_SECRET_KEY=replace_me
ARTIFACT_S3_BUCKET=vani-artifacts-non-sensitive
MONGODB_TRACE_WRITES_ENABLED=true
