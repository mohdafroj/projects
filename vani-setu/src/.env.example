APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://vanisetu.rajyasabha.digital

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=vani_setu
DB_USERNAME=vani
DB_PASSWORD=vani_secret
# Encrypt the DB link.
#   require    = encrypt, no cert check (downgrade guard)        <-- in use
#   verify-ca  = + pin the server cert via DB_SSLROOTCERT (MITM guard)
#   verify-full= + check cert hostname
# CAVEAT (2026-06-14): verify-ca works from the CLI but 500s under php-fpm in
# this env even with a world-readable cert + fpm reload — DB-querying endpoints
# break. Left at `require` until that php-fpm/PDO TLS issue is understood. The
# sslrootcert plumbing + cert below are kept so verify-ca can be re-enabled once
# it's fixed. Regenerate the pinned root cert (public, self-signed, to 2036):
#   openssl s_client -starttls postgres -connect 10.21.217.133:5432 -showcerts \
#     </dev/null 2>/dev/null | openssl x509 -outform PEM \
#     > storage/app/certs/devdb-ca.crt   # then chmod 644
DB_SSLMODE=require
# DB_SSLROOTCERT=/var/www/html/storage/app/certs/devdb-ca.crt

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMPLOYEE_ID=

SESSION_DRIVER=redis
SESSION_LIFETIME=60
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=vanisetu.rajyasabha.digital
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
TRUSTED_PROXIES=10.42.0.0/16,172.16.0.0/12,127.0.0.1
CORS_ALLOWED_ORIGINS=https://vanisetu.rajyasabha.digital
SANCTUM_TOKEN_EXPIRATION=480
SANCTUM_TOKEN_PREFIX=vst_

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
REPORTER_AUDIO_DISK=vani_audio
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=vanisetu.rajyasabha.digital

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VANI_MINIO_ENDPOINT=minio.data.svc.cluster.local:9000
VANI_MINIO_ACCESS_KEY=
VANI_MINIO_SECRET_KEY=
VANI_MINIO_AUDIO_BUCKET=vani-audio-raw-rs
VANI_MINIO_REGION=us-east-1

SYNOPSIS_MODEL_URL=http://ml-gateway:8000/v1/synopsis
SYNOPSIS_MODEL_ALLOWED_HOSTS=ml-gateway
SYNOPSIS_MODEL=vani-setu-synopsis
SYNOPSIS_MODEL_TOKEN=
SYNOPSIS_MODEL_TIMEOUT=20
SYNOPSIS_MODEL_RETRIES=1
SYNOPSIS_MODEL_RETRY_SLEEP_MS=250

TIJORI_ASR_URL=http://tijori-router.tijori-system.svc.cluster.local/v1/asr
TIJORI_SERVICE_TOKEN=
TIJORI_ASR_TIMEOUT=20
TIJORI_ASR_RETRIES=2
TIJORI_ASR_RETRY_SLEEP_MS=250

# Sarvam S2S — see docs/vani-setu-poc-handover.md for rationale on each value.
SARVAM_API_BASE=https://api.sarvam.ai
SARVAM_VOICE_PIPELINE_URL=http://ml-gateway:8000/v1/speech-to-speech
SARVAM_TIMEOUT=20
SARVAM_RETRIES=1
SARVAM_RETRY_SLEEP_MS=250
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=codemix
SARVAM_STT_PATH=/speech-to-text
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_TRANSLATE_MODE=formal
SARVAM_TRANSLATE_PATH=/translate
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_PATH=/text-to-speech
SARVAM_TTS_PACE=1.1
SARVAM_TTS_SAMPLE_RATE=22050
SARVAM_TTS_CODEC=wav

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=vanisetu
REVERB_APP_KEY=replace-me
REVERB_APP_SECRET=replace-me
REVERB_HOST=vanisetu.rajyasabha.digital
REVERB_PORT=443
REVERB_SCHEME=https

SB_IAM_URL=https://ft.rajyasabha.digital
SB_IAM_CLIENT_ID=
SB_IAM_CLIENT_SECRET=

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"


NOTIFICATION_SEND_EMAIL=true
NOTIFICATION_SEND_SMS=false
NOTIFICATION_SEND_WHATSAPP=false
NOTIFICATION_ENGINE_SERVICE_TOKENS=
SMS_GATEWAY_API_URL=
SMS_GATEWAY_USERNAME=
SMS_GATEWAY_PIN=
SMS_GATEWAY_SIGNATURE=
SMS_GATEWAY_DLT_ENTITY_ID=
SMS_GATEWAY_TIMEOUT=10
WHATSAPP_GATEWAY_API_URL=
WHATSAPP_GATEWAY_TOKEN=
WHATSAPP_GATEWAY_TIMEOUT=10

S2S_STREAMING_TTS=false
S2S_DISK_AUDIO=false
S2S_COMPRESS_SOURCE_AUDIO=true
S2S_COMPRESS_MIN_BYTES=65536
S2S_AUDIO_ARCHIVE_RETENTION_DAYS=30
S2S_AUDIO_ARCHIVE_PRUNE_BATCH=500
S2S_LATENCY_HEALTH_WINDOW_MINUTES=30
S2S_LATENCY_P95_WATCH_MS=3500
S2S_LATENCY_P95_DEGRADED_MS=6000
S2S_CLIENT_ERROR_DEGRADED_THRESHOLD=5
S2S_CLIENT_LIVE_KIND_DEGRADED_THRESHOLD=3
S2S_CLIENT_LANGUAGE_DEGRADED_THRESHOLD=3

# S2S recheck engine (slice D)
# Driver: 'null' surfaces 'failed' until configured; 'ml_gateway' routes
# second-pass ASR through the gateway over a signed internal URL.
S2S_RECHECK_TRANSCRIBER=null
S2S_RECHECK_GATEWAY_URL=http://vani-setu-ml-gateway:8000
S2S_RECHECK_INTERNAL_URL=http://vani-setu-web
S2S_RECHECK_URL_TTL=300
S2S_RECHECK_TIMEOUT=25
S2S_RECHECK_DRIFT_THRESHOLD=0.15
S2S_RECHECK_CORRECTION_CONFIDENCE=0.85
S2S_RECHECK_AUTO_DISPATCH=false
